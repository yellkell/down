rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // "X WAS HERE" marks left at the finish zone. Anyone can read the wall
    // and add exactly one shape of document; nothing can ever be edited or
    // removed from the client.
    match /marks/{mark} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 't'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 10
        && request.resource.data.name.matches('[A-Z0-9 ]+')
        && request.resource.data.t == request.time;
      allow update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
